rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /user/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /merchants/{merchantId} {
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    match /subscriptions/{merchantId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/merchants/$(merchantId)).data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    match /merchant_counters/{merchantId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/merchants/$(merchantId)).data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    match /programs/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /StampCards/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /Transactions/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /Rewards/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }
  }
}
